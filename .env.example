# Copy this file to .env and fill in real values. Never commit .env to git.

# SQL Server — read-only service account for TenantDB
DB_CONNECTION_STRING=mssql+pyodbc://casci_ro:<password>@<host>/<db>?driver=ODBC+Driver+17+for+SQL+Server

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith — tracing and eval
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=casci-scenario-planning

# Optional overrides (defaults set in settings.py)
# LLM_SCENARIO_GENERATOR=claude-sonnet-4-6
# LLM_DEMAND_DECOMP=claude-sonnet-4-6
# LLM_NARRATION=claude-haiku-4-5-20251001
