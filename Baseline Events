--Customer + Event Identification

SELECT
    e.id                            AS event_id,
    e.code                          AS event_code,
    e.name                          AS event_name,
    e.start_date                    AS event_start,
    e.end_date                      AS event_end,
    DATEDIFF(day, e.start_date,
             e.end_date) + 1        AS event_duration_days,
    e.event_lag_days,
    e.warning_days,

    -- Product
    p.id                            AS product_id,
    p.code                          AS product_code,
    p.name                          AS product_name,
    pc.code                         AS product_class,
    pg.code                         AS product_group,
    pf.code                         AS product_family,

    -- Location
    l.id                            AS location_id,
    l.code                          AS location_code,
    l.name                          AS location_name,

    -- Customer
    c.id                            AS customer_id,
    c.code                          AS customer_code,
    c.name                          AS customer_name,
    seg.name                        AS customer_segment,

    -- Event config
    eplcx.expected_uplift           AS planned_uplift_total,
    eplcx.expected_demand           AS planned_demand_total,
    eplcx.quantity_ordered,
    eplcx.event_minimum,
    eplcx.is_recal_uplift

FROM event e
JOIN event_prod_loc_cust_xref   eplcx  ON eplcx.event_id       = e.id
                                       AND eplcx.is_deleted     = 0
JOIN product_location_customer_xref plc ON plc.id              = eplcx.prod_loc_cust_id
                                       AND plc.is_deleted       = 0
JOIN product                    p      ON p.id                  = plc.product_id
JOIN location                   l      ON l.id                  = plc.location_id
JOIN customer                   c      ON c.id                  = plc.customer_id
JOIN product_class              pc     ON pc.id                 = p.product_class_id
JOIN product_group              pg     ON pg.id                 = p.product_primary_group_id
JOIN product_family             pf     ON pf.id                 = p.product_family_id
JOIN segment                    seg    ON seg.id                = c.segment_id
WHERE e.id          = 41
  AND e.is_deleted  = 0
ORDER BY p.code, l.code, c.code


--Planned vs Actual Uplift

SELECT
    'planned'                       AS uplift_source,
    plc.product_id,
    plc.location_id,
    plc.customer_id,
    h_uplift.start_date             AS period_start,
    h_uplift.end_date               AS period_end,
    h_uplift.uplift_value           AS planned_uplift_units,
    h_xref.expected_uplift          AS planned_uplift_total,
    h_xref.expected_demand          AS planned_demand_total,
    h_xref.adjustment_type,
    h_xref.adjustment_period_type
FROM event_prod_loc_cust_uplift_History  h_uplift
JOIN event_prod_loc_cust_xref_history    h_xref
    ON  h_xref.id           = h_uplift.event_prod_loc_cust_id
    AND h_xref.StartTime   <=  (SELECT CAST(DATEADD(day, -14, start_date) AS DATE)
                                 FROM   event WHERE id = 41)
    AND h_xref.EndTime      > (SELECT CAST(DATEADD(day, -14, start_date) AS DATE)
                                 FROM   event WHERE id = 41)
JOIN product_location_customer_xref plc
    ON  plc.id              = h_xref.prod_loc_cust_id
JOIN event e ON e.id        = h_xref.event_id
-- Snapshot: only uplift records that existed at T-14
WHERE h_uplift.StartTime   <= (SELECT CAST(DATEADD(day, -14, start_date) AS DATE)
                                 FROM   event WHERE id = 41)
  AND h_uplift.EndTime      > (SELECT CAST(DATEADD(day, -14, start_date) AS DATE)
                                 FROM   event WHERE id = 41)
  AND e.id                  = 41

UNION ALL

-- Actual uplift from demand_history (signal = 'event', signal_id = 4)
-- Unpivots P1-P156 for periods overlapping the event window

SELECT
    'actual'                        AS uplift_source,
    plc.product_id,
    plc.location_id,
    plc.customer_id,
    dp.period_start                   AS period_start,
    dp.period_end                     AS period_end,
    unpvt.demand_value              AS actual_event_demand,
    NULL                            AS planned_uplift_total,
    NULL                            AS planned_demand_total,
    NULL                            AS adjustment_type,
    NULL                            AS adjustment_period_type
FROM demand_history dh
JOIN demand_signal ds
    ON  ds.id       = dh.demand_signal_id
    AND ds.name     = 'event'           -- signal_id = 4
JOIN product_location_customer_xref plc
    ON  plc.id      = dh.prod_loc_cust_id
JOIN event_prod_loc_cust_xref eplcx
    ON  eplcx.prod_loc_cust_id = plc.id
    AND eplcx.event_id         = 41
JOIN event e ON e.id           = 41
