### 6.3 LangGraph Graph Definition

```python
from langgraph.graph import StateGraph, END
from scenario_planning.state import ScenarioPlanningState
from scenario_planning.agents import (
    orchestrator_agent, route_after_orchestrator,
    demand_decomposition_agent, supply_constraint_agent,
    scenario_generator_agent, financial_impact_agent,
    present_scenarios
)


def build_scenario_planning_graph():
    graph = StateGraph(ScenarioPlanningState)

    # Register nodes
    graph.add_node("orchestrator",          orchestrator_agent)
    graph.add_node("demand_decomposition",  demand_decomposition_agent)
    graph.add_node("supply_constraint",     supply_constraint_agent)
    graph.add_node("scenario_generator",    scenario_generator_agent)
    graph.add_node("financial_impact",      financial_impact_agent)
    graph.add_node("present_to_planner",    present_scenarios)

    # Entry point
    graph.set_entry_point("orchestrator")

    # Orchestrator routes to parallel analysis or error
    graph.add_conditional_edges(
        "orchestrator",
        route_after_orchestrator,
        {
            "run_analysis": ["demand_decomposition", "supply_constraint"],  # parallel
            "error": END
        }
    )

    # Both analysis agents must complete before scenario generator runs
    graph.add_edge("demand_decomposition", "scenario_generator")
    graph.add_edge("supply_constraint",    "scenario_generator")

    # Sequential from scenario generation onward
    graph.add_edge("scenario_generator",   "financial_impact")
    graph.add_edge("financial_impact",     "present_to_planner")
    graph.add_edge("present_to_planner",   END)

    return graph.compile()


def run_scenario_planning(event: PromotionalEvent) -> ScenarioPlanningState:
    graph = build_scenario_planning_graph()
    initial_state: ScenarioPlanningState = {
        "event": event,
        "demand_decomposition": None,
        "supply_constraints": None,
        "scenarios": None,
        "financial_impacts": None,
        "current_step": "orchestrator",
        "errors": [],
        "planner_selection": None,
        "messages": []
    }
    return graph.invoke(initial_state)
```

